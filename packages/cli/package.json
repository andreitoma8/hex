{
  "name": "solaudit",
  "version": "0.1.1",
  "description": "CLI toolkit for Solidity smart contract auditors",
  "type": "module",
  "bin": {
    "solaudit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "copy-skills": "node -e \"const fs=require('fs');const p=require('path');fs.cpSync(p.join('src','skills'),p.join('dist','skills'),{recursive:true})\"",
    "build": "tsc && npm run copy-skills",
    "dev": "npm run copy-skills && tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "solidity",
    "audit",
    "smart-contracts",
    "security"
  ],
  "license": "MIT",
  "dependencies": {
    "@solidity-parser/parser": "^0.18.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.3.10",
    "ora": "^8.0.1",
    "tiktoken": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
