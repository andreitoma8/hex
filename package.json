{
  "name": "hex-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/cli",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "test": "npm run test --workspace=packages/cli",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
